{% block head_extra %}
  <style>
    .fest-hero {
      background: linear-gradient(180deg, var(--bg) 0%, var(--cream) 100%);
      position: relative;
      overflow: hidden;
      padding: clamp(2.5rem, 5vw, 4.5rem) 0 0;
    }
    .fest-hero-grid {
      max-width: var(--content);
      margin-inline: auto;
      padding-inline: var(--gutter);
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: clamp(2rem, 4vw, 4rem);
      align-items: end;
      position: relative;
      z-index: 1;
    }
    @media (max-width: 920px) { .fest-hero-grid { grid-template-columns: 1fr; } }
    .fest-hero h1 {
      font-size: clamp(3rem, 9vw, 7rem);
      letter-spacing: -0.03em;
      line-height: 0.95;
    }
    .fest-hero h1 em { color: var(--accent-2); display: inline-block; }
    .fest-hero .subhead {
      font-family: var(--font-display);
      font-style: italic;
      font-size: clamp(1.4rem, 2.4vw, 2rem);
      color: var(--ink-soft);
      margin: 1rem 0 1.5rem;
      line-height: 1.2;
    }
    .fest-stats {
      max-width: var(--content);
      margin-inline: auto;
      padding: clamp(2rem, 4vw, 3rem) var(--gutter) 0;
    }
    .fest-stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      border-top: 1px solid var(--line-strong);
      border-bottom: 1px solid var(--line-strong);
    }
    @media (max-width: 720px) { .fest-stats-grid { grid-template-columns: repeat(2, 1fr); } }
    .fest-stat { padding: 1.5rem 1.25rem; border-right: 1px solid var(--line); }
    .fest-stat:last-child { border-right: 0; }
    .fest-stat .label {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink-mute);
      margin-bottom: 0.5rem;
    }
    .fest-stat .val {
      font-family: var(--font-display);
      font-size: clamp(1.3rem, 2vw, 1.6rem);
      color: var(--brand);
      line-height: 1.1;
    }
    .fest-stat .val em { color: var(--accent-2); }

    .program {
      max-width: var(--content);
      margin-inline: auto;
      padding-inline: var(--gutter);
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    @media (max-width: 820px) { .program { grid-template-columns: 1fr; } }
    .prog-card {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--r-lg);
      padding: 1.5rem;
      position: relative;
      overflow: hidden;
    }
    .prog-card .num {
      font-family: var(--font-display);
      font-style: italic;
      color: var(--accent-2);
      font-size: 1.5rem;
      margin-bottom: 0.6rem;
      display: block;
    }
    .prog-card h3 { margin-bottom: 0.5rem; font-size: 1.35rem; }
    .prog-card p { color: var(--ink-soft); font-size: 0.95rem; }

    .venue { background: var(--brand); color: var(--ivory); }
    .venue-grid {
      max-width: var(--content);
      margin-inline: auto;
      padding: clamp(3rem, 5vw, 4.5rem) var(--gutter);
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 3rem;
      align-items: center;
    }
    @media (max-width: 820px) { .venue-grid { grid-template-columns: 1fr; } }
    .venue h2, .venue h2 em { color: var(--ivory); }
    .venue h2 em { color: var(--saffron); font-style: italic; }
    .venue p { color: rgba(245, 239, 226, 0.78); }
    .venue .label {
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--saffron);
      margin-bottom: 0.4rem;
      font-weight: 600;
    }
    .venue-map {
      aspect-ratio: 4 / 3;
      border-radius: var(--r-lg);
      background:
        radial-gradient(circle at 30% 40%, var(--saffron) 0 8px, transparent 9px),
        radial-gradient(circle at 30% 40%, rgba(232,163,59,0.25) 0 22px, transparent 23px),
        repeating-linear-gradient(45deg, rgba(255,255,255,0.04) 0 1px, transparent 1px 18px),
        linear-gradient(135deg, var(--plum-soft), var(--plum-deep));
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.08);
    }
    .venue-map .pin {
      position: absolute;
      top: 38%; left: 30%;
      font-family: var(--font-display);
      font-style: italic;
      color: var(--saffron);
      font-size: 1.2rem;
      transform: translate(0.8rem, -0.3rem);
    }
    .venue-map .label-flat {
      position: absolute;
      top: 14%; left: 8%;
      font-family: var(--font-body);
      font-size: 0.65rem;
      color: rgba(245,239,226,0.45);
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }
    .venue-map .label-flat.b { top: auto; left: auto; bottom: 12%; right: 8%; }
    .venue-map .river {
      position: absolute;
      bottom: 20%; left: 0; right: 0;
      height: 14px;
      background: rgba(46,125,125,0.5);
      transform: skewY(-3deg);
    }
    .venue-map svg.park {
      position: absolute;
      inset: 18% 18% 25% 38%;
      width: auto; height: auto;
      opacity: 0.55;
    }
  </style>
{% endblock %}

{% block content %}
  <!-- Festival hero -->
  <section class="fest-hero">
    <div class="fest-hero-grid">
      <div>
        <span class="past-banner">Past event · April 2026</span>
        <p class="eyebrow">ICCL flagship festival · 2026 edition</p>
        <h1>MOMO Fest<br>Melbourne <em>'26</em></h1>
        <p class="subhead">Two days. One park.<br>Thirty-plus kitchens. Endless momo.</p>
        <p class="lede" style="max-width: 50ch;">A free, family-friendly cultural and culinary festival that celebrated MOMO — the beloved Nepali and Himalayan dumpling — alongside the music, dance and food of multicultural Melbourne.</p>
        <div class="hero-actions" style="margin-top: 1.5rem;">
          <a href="https://www.momofest.com.au" target="_blank" rel="noopener noreferrer" class="btn btn-accent">MOMO Fest site <span class="ar">→</span></a>
          <a href="#program" class="btn btn-ghost">Programme highlights</a>
        </div>
      </div>
      <div class="hero-media" style="aspect-ratio: 3 / 4;">
        <img src="assets/MOMOFest-Thankyou.%20hero%20event.jpg"
             alt="Thank-you image showing the crowd at MOMO Fest Melbourne 2026, held at Footscray Park on 11–12 April 2026"
             width="1080" height="1350" fetchpriority="high">
        <span class="hero-tag" style="background: var(--plum); color: var(--saffron);">RECAP · 11–12 APR 2026</span>
      </div>
    </div>

    <div class="fest-stats">
      <div class="fest-stats-grid">
        <div class="fest-stat">
          <div class="label">Dates</div>
          <div class="val">Sat <em>11</em> &amp; Sun <em>12</em> April</div>
        </div>
        <div class="fest-stat">
          <div class="label">Hours</div>
          <div class="val">12<em>pm</em> – 10<em>pm</em></div>
        </div>
        <div class="fest-stat">
          <div class="label">Venue</div>
          <div class="val">Footscray <em>Park</em></div>
        </div>
        <div class="fest-stat">
          <div class="label">Entry</div>
          <div class="val">Free · all welcome</div>
        </div>
      </div>
    </div>
  </section>

  <div class="flagband tall" aria-hidden="true">
    <span></span><span></span><span></span><span></span><span></span>
  </div>

  <!-- Programme highlights -->
  <section class="section" id="program">
    <div class="section-head">
      <div>
        <p class="eyebrow">What was on</p>
        <h2>Two days,<br>plenty to <em>chew on.</em></h2>
      </div>
      <p class="lede">Across the weekend, MOMO Fest 2026 ran a steady rotation of music, performance, family activities and — the heart of it — a great deal of momo. Highlights of the 2026 programme:</p>
    </div>

    <div class="program">
      <article class="prog-card">
        <span class="num">01 ·</span>
        <h3>MOMO &amp; food vendors</h3>
        <p>30+ Nepali, Himalayan and multicultural food stalls served everything from steamed and pan-fried momo to thukpa, sel roti, chaat, dumplings and beyond.</p>
      </article>
      <article class="prog-card">
        <span class="num">02 ·</span>
        <h3>Live music &amp; performance</h3>
        <p>Two stages ran across the weekend featuring Nepali, Tibetan, Bhutanese, Indian and Australian artists, with roving performers and dance throughout the park.</p>
      </article>
      <article class="prog-card">
        <span class="num">03 ·</span>
        <h3>Family &amp; community</h3>
        <p>Children's activities, amusement rides, games, market stalls and a community space — designed for groups, families and first-time visitors alike.</p>
      </article>
      <article class="prog-card">
        <span class="num">04 ·</span>
        <h3>Licensed bar</h3>
        <p>A licensed bar ran alongside non-alcoholic drinks and chiya (Nepali milk tea). All beverages were sold by licensed vendors.</p>
      </article>
      <article class="prog-card">
        <span class="num">05 ·</span>
        <h3>Cultural showcase</h3>
        <p>A daily showcase highlighted Nepali and Himalayan craft, dress and ritual — alongside multicultural Australian artists and makers.</p>
      </article>
      <article class="prog-card">
        <span class="num">06 ·</span>
        <h3>Accessibility</h3>
        <p>Footscray Park is largely flat with accessible paths, public toilets and easy public transport — well suited to a free public festival of this scale.</p>
      </article>
    </div>
  </section>

  {#
  Gallery — hidden until photos are sorted from the weekend's frames.
  Uncomment when ready. Slots `g1`..`g8` were originally <image-slot> drop targets.
  -->
  <section class="section" style="background: var(--cream); padding-block: clamp(3rem, 5vw, 4.5rem);">
    <div class="section-head">
      <div>
        <p class="eyebrow">Festival mood</p>
        <h2>Tastes, faces,<br><em>the crowd at dusk.</em></h2>
      </div>
      <p class="lede">A glimpse of MOMO Fest 2026 at Footscray Park.</p>
    </div>
    <div class="gallery">
      <img src="assets/g1.jpg" alt="Festival hero">
      ...
    </div>
  </section>
  #}

  <!-- Venue / map block -->
  <section class="venue">
    <div class="venue-grid">
      <div>
        <p class="eyebrow" style="color: var(--saffron);">Venue · Footscray Park</p>
        <h2>One of Melbourne's<br>great <em>public parks.</em></h2>
        <p class="lede" style="color: rgba(245,239,226,0.85); margin-top: 1rem;">Footscray Park sits on Wurundjeri Country alongside the Maribyrnong River — minutes from the city by train, with the Footscray Market and Little Saigon a short walk away.</p>

        <div style="display:grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; margin-top: 1.5rem;">
          <div>
            <div class="label">Address</div>
            <p style="font-size: 0.95rem;">Footscray Park<br>Ballarat Road<br>Footscray VIC 3011</p>
          </div>
          <div>
            <div class="label">Getting there</div>
            <p style="font-size: 0.95rem;">Train: Footscray Station<br>(7 min walk)<br>Bus &amp; tram nearby</p>
          </div>
        </div>

        <div class="hero-actions" style="margin-top: 1.5rem;">
          <a href="https://maps.google.com/?q=Footscray+Park+Melbourne" target="_blank" rel="noopener noreferrer" class="btn" style="background: var(--saffron); color: var(--plum);">Open in Maps <span class="ar">→</span></a>
        </div>
      </div>

      <div class="venue-map" aria-hidden="true">
        <span class="label-flat">FOOTSCRAY</span>
        <span class="label-flat b">MARIBYRNONG</span>
        <span class="pin">Festival site</span>
        <div class="river"></div>
        <svg class="park" viewBox="0 0 200 130" preserveAspectRatio="none">
          <path d="M10,30 Q30,8 80,12 Q140,16 180,40 Q190,80 150,110 Q90,128 40,108 Q-2,80 10,30 Z"
                fill="rgba(46,125,125,0.35)" stroke="rgba(232,163,59,0.6)" stroke-width="1.2" stroke-dasharray="3 3"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- Future events -->
  <section class="section" id="future" style="background: var(--cream);">
    <div class="section-head">
      <div>
        <p class="eyebrow">Looking ahead</p>
        <h2>Future <em>events.</em></h2>
      </div>
      <p class="lede">MOMO Fest will return — and ICCL is planning new cultural programs alongside it. Specific dates and venues will be announced as they are confirmed.</p>
    </div>

    <div class="future">
      <div class="future-card">
        <span class="stamp">Coming soon</span>
        <h3>Next edition <em>to be announced.</em></h3>
        <p>Follow ICCL on Facebook or email the events team to be the first to hear about the next MOMO Fest, partnership opportunities and upcoming ICCL programs.</p>
        <div class="hero-actions">
          <a href="https://www.facebook.com/iccl.org.au" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Follow on Facebook <span class="ar">→</span></a>
          <a href="mailto:events@iccl.org.au" class="btn btn-ghost">events@iccl.org.au</a>
        </div>
        <div class="meta-row">
          <span class="dot"></span>
          <span>Updates via Facebook &amp; email</span>
        </div>
      </div>
    </div>
  </section>
{% endblock %}
